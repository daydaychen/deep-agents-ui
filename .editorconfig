# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# 2 space indentation for most files
[*.{ts,tsx,js,jsx,json,yml,yaml,css,scss,md}]
indent_style = space
indent_size = 2
max_line_length = 140

# 4 space indentation for Python files
[*.py]
indent_style = space
indent_size = 4

# Tab indentation for Makefiles
[Makefile]
indent_style = tab

# Don't trim trailing whitespace in Markdown files (preserves intentional line breaks)
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Specific rules for package.json
[package.json]
indent_style = space
indent_size = 2
