# pnpm configuration
# https://pnpm.io/npmrc

# Use exact versions instead of semver ranges
save-exact=false

# Automatically install peer dependencies
auto-install-peers=true

# Use hoisted node_modules structure for compatibility
node-linker=isolated

# Enable strict peer dependencies check
strict-peer-dependencies=false

# Registry configuration
registry=https://registry.npmjs.org/

# Hoist patterns for better compatibility
hoist-pattern[]=*

# Shamefully hoist for packages that need it
shamefully-hoist=false

# Store directory
store-dir=.pnpm-store

# Virtual store directory
virtual-store-dir=.pnpm
