{
  "name": "deep-agents-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:debug": "NODE_OPTIONS='--inspect' next dev --turbopack",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "lint:fix:unsafe": "biome lint --write --unsafe .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check:fix:unsafe": "biome check --write --unsafe .",
    "organize-imports": "biome organize --write .",
    "type-check": "tsc --noEmit",
    "type-check:strict": "./scripts/type-check.sh --strict",
    "clean": "rm -rf .next node_modules/.cache",
    "clean:all": "rm -rf .next node_modules pnpm-lock.yaml",
    "setup": "./scripts/setup-dev.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@langchain/core": "^1.1.5",
    "@langchain/langgraph": "^1.2.3",
    "@langchain/langgraph-sdk": "^1.7.4",
    "@radix-ui/colors": "^1.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/diff": "^5.0.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^9.0.8",
    "@uiw/react-json-view": "2.0.0-alpha.41",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^1.2.1",
    "date-fns": "^4.1.0",
    "diff": "^8.0.2",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.577.0",
    "next": "^16.0.7",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "nuqs": "^2.4.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^9.0.1",
    "react-resizable-panels": "^3.0.6",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.0",
    "sass": "^1.90.0",
    "sonner": "^2.0.7",
    "swr": "^2.3.6",
    "tailwind-merge": "^2.6",
    "uuid": "^9.0.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@headlessui/tailwindcss": "^0.2.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.9",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.22",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@9.15.0",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{json,css,scss,md,yml,yaml}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  }
}
