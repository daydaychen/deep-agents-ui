# Databus Pilot 环境变量配置示例
# 复制此文件为 .env.local 或 .env.production 等，并填入实际值

# ================================================
# 后端服务配置 (必需)
# ================================================

# LangGraph 后端部署 URL (服务端变量，不会暴露给客户端)
# 格式: https://your-deployment-url.com
LANGGRAPH_DEPLOYMENT_URL=

# ================================================
# 可选配置
# ================================================

# LangGraph API 密钥 (可选，服务端注入为 x-api-key 请求头)
# LANGGRAPH_API_KEY=

# 应用端口 (开发环境)
PORT=3003
